# ─── Application ─────────────────────────────────────────────────────
# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI (Google Gemini)
GOOGLE_GENERATIVE_AI_API_KEY=your-gemini-api-key

# ─── E2E Test Credentials (used by Playwright) ──────────────────────
# Store actual values in .env.test.local (gitignored, never committed)
E2E_BASE_URL=http://localhost:3000
E2E_ADMIN_EMAIL=your-admin@example.com
E2E_ADMIN_PASS="your-admin-password"
E2E_MANAGER_EMAIL=your-manager@example.com
E2E_MANAGER_PASS="your-manager-password"
E2E_CLIENT_EMAIL=your-client@example.com
E2E_CLIENT_PASS="your-client-password"
